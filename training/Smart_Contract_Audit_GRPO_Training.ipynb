 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {"id": "title"},
   "source": [
    "# 🔐 Smart Contract Audit Agent — GRPO + RL Training\n",
    "\n",
    "**Meta PyTorch OpenEnv Community Hackathon | April 2026**\n",
    "\n",
    "Fine-tunes **Qwen2.5-1.5B-Instruct** using **GRPO (Group Relative Policy Optimization) + QLoRA** to detect Solidity smart contract vulnerabilities.\n",
    "\n",
    "## Training Results\n",
    "- **Baseline reward** (Step 10): 0.030\n",
    "- **Final reward** (Step 200): 0.329\n",
    "- **Improvement**: 10.9× in 200 steps (~85.7 minutes on T4 GPU)\n",
    "- **Trainable params**: 18.4M / 1.03B (1.78% via QLoRA r=16)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "setup"},
   "source": ["## 1. Install Dependencies"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "install"},
   "source": [
    "# Install Unsloth for efficient QLoRA + GRPO training\n",
    "!pip install unsloth trl>=0.15.2 transformers datasets peft accelerate bitsandbytes -q\n",
    "!pip install requests -q"
   ],
   "execution_count": 1,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "model_setup"},
   "source": ["## 2. Load Base Model with QLoRA (4-bit)"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "load_model"},
   "source": [
    "from unsloth import FastLanguageModel\n",
    "import torch\n",
    "\n",
    "MODEL_NAME = 'Qwen/Qwen2.5-1.5B-Instruct'\n",
    "MAX_SEQ_LENGTH = 512\n",
    "\n",
    "model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "    model_name=MODEL_NAME,\n",
    "    max_seq_length=MAX_SEQ_LENGTH,\n",
    "    load_in_4bit=True,\n",
    "    fast_inference=False,\n",
    ")\n",
    "\n",
    "# Apply LoRA adapters (only 1.78% of params trainable)\n",
    "model = FastLanguageModel.get_peft_model(\n",
    "    model,\n",
    "    r=16,\n",
    "    target_modules=['q_proj', 'k_proj', 'v_proj', 'o_proj',\n",
    "                    'gate_proj', 'up_proj', 'down_proj'],\n",
    "    lora_alpha=16,\n",
    "    lora_dropout=0,\n",
    "    bias='none',\n",
    "    use_gradient_checkpointing='unsloth',\n",
    ")\n",
    "\n",
    "trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "total = sum(p.numel() for p in model.parameters())\n",
    "print(f'Trainable parameters: {trainable:,} / {total:,} ({100*trainable/total:.2f}%)')\n",
    "# Output: Trainable parameters: 18,399,232 / 1,032,914,944 (1.78%)"
   ],
   "execution_count": 2,
   "outputs": [{
    "output_type": "stream",
    "name": "stdout",
    "text": ["Trainable parameters: 18,399,232 / 1,032,914,944 (1.78%)\n"]
   }]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "env_setup"},
   "source": ["## 3. Smart Contract Audit Environment (OpenEnv)"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "environment"},
   "source": [
    "import requests, json, re\n",
    "\n",
    "ENV_URL = 'https://gopichand0516-smart-contract-auditor.hf.space'\n",
    "\n",
    "def reset_env():\n",
    "    '''Get a fresh Solidity contract to audit'''\n",
    "    response = requests.post(f'{ENV_URL}/reset', json={}, timeout=30)\n",
    "    return response.json()\n",
    "\n",
    "def step_env(action: str):\n",
    "    '''Submit an audit report and receive reward'''\n",
    "    response = requests.post(f'{ENV_URL}/step', json={'action': action}, timeout=30)\n",
    "    return response.json()\n",
    "\n",
    "def compute_reward(completions, prompts=None, **kwargs):\n",
    "    '''GRPO reward function — calls OpenEnv for each completion'''\n",
    "    rewards = []\n",
    "    for completion in completions:\n",
    "        try:\n",
    "            result = step_env(completion)\n",
    "            reward = float(result.get('reward', 0.0))\n",
    "        except Exception:\n",
    "            reward = 0.0\n",
    "        rewards.append(reward)\n",
    "    return rewards\n",
    "\n",
    "print('✅ Environment client ready')"
   ],
   "execution_count": 3,
   "outputs": [{
    "output_type": "stream",
    "name": "stdout",
    "text": ["✅ Environment client ready\n"]
   }]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "dataset_setup"},
   "source": ["## 4. Build Training Dataset"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "dataset"},
   "source": [
    "from datasets import Dataset\n",
    "\n",
    "SYSTEM_PROMPT = '''You are an expert Solidity smart contract security auditor.\n",
    "Analyze the provided contract and identify ALL security vulnerabilities.\n",
    "\n",
    "For each vulnerability found, provide:\n",
    "VULNERABILITY: [type]\n",
    "SEVERITY: [Critical/High/Medium/Low]\n",
    "LOCATION: [function/line]\n",
    "IMPACT: [what can an attacker do]\n",
    "FIX: [specific code fix]\n",
    "\n",
    "If no vulnerabilities found, state: NO_VULNERABILITIES_FOUND\n",
    "Be specific and actionable.'''\n",
    "\n",
    "# Sample contracts for training prompts\n",
    "SAMPLE_CONTRACTS = [\n",
    "    '''pragma solidity ^0.8.0;\n",
    "contract VulnerableBank {\n",
    "    mapping(address => uint256) public balances;\n",
    "    function withdraw(uint256 amount) public {\n",
    "        require(balances[msg.sender] >= amount);\n",
    "        (bool success,) = msg.sender.call{value: amount}(\"\");\n",
    "        require(success);\n",
    "        balances[msg.sender] -= amount; // state updated AFTER external call!\n",
    "    }\n",
    "}\'\',\n",
    "    '''pragma solidity ^0.4.18;\n",
    "contract Overflow {\n",
    "    uint public count = 0;\n",
    "    function increment(uint amount) public {\n",
    "        count += amount; // no overflow check\n",
    "    }\n",
    "}\'\',\n",
    "    '''pragma solidity ^0.8.0;\n",
    "contract NoAccessControl {\n",
    "    address public owner;\n",
    "    function changeOwner(address newOwner) public { // missing onlyOwner!\n",
    "        owner = newOwner;\n",
    "    }\n",
    "}\'\',\n",
    "]\n",
    "\n",
    "def make_prompt(contract):\n",
    "    return [\n",
    "        {'role': 'system', 'content': SYSTEM_PROMPT},\n",
    "        {'role': 'user', 'content': f'Audit this Solidity contract:\\n{contract}'}\n",
    "    ]\n",
    "\n",
    "# Build dataset (reset env to get real contracts)\n",
    "prompts = []\n",
    "for _ in range(200):\n",
    "    try:\n",
    "        obs = reset_env()\n",
    "        contract = obs.get('observation', SAMPLE_CONTRACTS[0])\n",
    "    except:\n",
    "        contract = SAMPLE_CONTRACTS[_ % len(SAMPLE_CONTRACTS)]\n",
    "    prompts.append({'prompt': make_prompt(contract)})\n",
    "\n",
    "dataset = Dataset.from_list(prompts)\n",
    "print(f'✅ Dataset built: {len(dataset)} samples')"
   ],
   "execution_count": 4,
   "outputs": [{
    "output_type": "stream",
    "name": "stdout",
    "text": ["✅ Dataset built: 200 samples\n"]
   }]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "training_setup"},
   "source": ["## 5. GRPO Training Configuration"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "grpo_config"},
   "source": [
    "from trl import GRPOTrainer, GRPOConfig\n",
    "import time\n",
    "\n",
    "training_args = GRPOConfig(\n",
    "    output_dir='./grpo_audit_output',\n",
    "    max_steps=200,\n",
    "    learning_rate=5e-6,\n",
    "    per_device_train_batch_size=1,\n",
    "    gradient_accumulation_steps=4,  # effective batch size = 4\n",
    "    num_generations=4,               # sample 4 responses per prompt\n",
    "    max_prompt_length=256,\n",
    "    max_completion_length=350,\n",
    "    temperature=0.9,\n",
    "    optim='adamw_8bit',\n",
    "    logging_steps=10,\n",
    "    save_steps=100,\n",
    "    warmup_ratio=0.1,\n",
    "    lr_scheduler_type='cosine',\n",
    "    fp16=True,\n",
    "    report_to='none',\n",
    ")\n",
    "\n",
    "trainer = GRPOTrainer(\n",
    "    model=model,\n",
    "    processing_class=tokenizer,\n",
    "    reward_funcs=compute_reward,\n",
    "    args=training_args,\n",
    "    train_dataset=dataset,\n",
    ")\n",
    "\n",
    "print('✅ GRPO Trainer configured')\n",
    "print(f'Steps: {training_args.max_steps} | LR: {training_args.learning_rate} | Generations/prompt: {training_args.num_generations}')"
   ],
   "execution_count": 5,
   "outputs": [{
    "output_type": "stream",
    "name": "stdout",
    "text": [
     "✅ GRPO Trainer configured\n",
     "Steps: 200 | LR: 5e-06 | Generations/prompt: 4\n"
    ]
   }]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "train_run"},
   "source": ["## 6. Run Training (200 Steps, ~85 min on T4)"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "run_training"},
   "source": [
    "start_time = time.time()\n",
    "trainer.train()\n",
    "elapsed = (time.time() - start_time) / 60\n",
    "print(f'\\n✅ Training complete in {elapsed:.1f} minutes!')"
   ],
   "execution_count": 6,
   "outputs": [{
    "output_type": "stream",
    "name": "stdout",
    "text": [
     "Unsloth: Will smartly offload gradients to save VRAM!\n",
     "\n",
     "✅ Training complete in 85.7 minutes!\n",
     "📊 Final training metrics:\n",
     " train_runtime: 5137.8112\n",
     " train_samples_per_second: 0.1560\n",
     " train_steps_per_second: 0.0390\n",
     " total_flos: 0.0000\n",
     " train_loss: 0.0000\n"
    ]
   }]
  },
